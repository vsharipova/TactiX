@model List<TactiX.Models.TrainingStage>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Тип</th>
                    <th>Hit Factor</th>
                    <th>Время</th>
                    <th>Alpha</th>
                    <th>Charlie</th>
                    <th>Delta</th>
                    <th>Miss</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stage in Model)
                {
                    <tr>
                        <td>@stage.StageName</td>
                        <td>@stage.StageType</td>
                        <td>@stage.HitFactor.ToString("F4")</td>
                        <td>@stage.StageTime.ToString(@"ss\.ff") сек</td>
                        <td>@stage.AlphasCount</td>
                        <td>@stage.CharliesCount</td>
                        <td>@stage.DeltasCount</td>
                        <td>@stage.MissesCount</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="EditTrainingStage" asp-route-id="@stage.TrainingStageId"
                                   class="btn btn-sm btn-outline-primary" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="DeleteTrainingStage" asp-route-id="@stage.TrainingStageId" method="post"
                                      onsubmit="return confirm('Удалить это упражнение?')" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                                @if (string.IsNullOrEmpty(stage.BriefingData))
                                {
                                    <button class="btn btn-sm btn-outline-success briefing-add-btn"
                                            title="Добавить брифинг"
                                            data-stage-id="@stage.TrainingStageId"
                                            data-stage-type="training">
                                        <i class="fas fa-plus"></i> Брифинг
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-info briefing-view-btn"
                                            title="Просмотреть брифинг"
                                            data-stage-id="@stage.TrainingStageId"
                                            data-stage-type="training"
                                            data-is-view="true">
                                        <i class="fas fa-eye"></i> Брифинг
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        Нет добавленных упражнений
    </div>
}

<script>
    $(function () {
        console.log('Training stages list loaded');
    });
</script>